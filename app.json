{
  "expo": {
    "name": "RAMonitorMobile",
    "slug": "RAMonitorMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ramonitormobile.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.ramonitormobile.app"
    },
    "plugins": [
      [
        "react-native-health",
        {
          "healthSharePermission": "RAMonitor reads steps, heart rate, gait and active energy to help you track rheumatoid arthritis patterns.",
          "healthUpdatePermission": "RAMonitor does not write health data."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "RAMonitor lets you choose food photos to upload and analyze."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
